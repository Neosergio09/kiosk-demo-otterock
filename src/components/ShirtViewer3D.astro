---
/**
 * ShirtViewer3D — Interactive 3D garment configurator
 * * AJUSTE: Solo se modificó el espaciado y tamaño del texto del header.
 * La lógica de JS y CSS del visor permanece intacta.
 */
---

<input type="hidden" id="placement-input" name="placement" value="front" />

<div id="shirt-viewer-root" class="flex flex-col gap-3 lg:gap-4">
  <div
    class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 px-6 lg:px-10 pt-4"
  >
    <div class="flex flex-col min-w-0">
      <p
        class="text-lg lg:text-2xl font-bold leading-tight tracking-tight"
        style="color:#202124;"
      >
        Configura tu prenda
      </p>
      <p class="text-[11px] lg:text-base mt-1" style="color:#5F6368;">
        Rota el modelo · elige ubicación del diseño
      </p>
    </div>
    <span
      id="placement-badge"
      class="flex items-center gap-2 px-4 py-2 rounded-full text-[10px] lg:text-xs font-bold uppercase tracking-widest transition-all duration-300 w-fit shrink-0 shadow-sm"
      style="background: rgba(66,133,244,0.10); border: 1px solid rgba(66,133,244,0.35); color: #4285F4;"
    >
      <span
        class="w-1.5 h-1.5 rounded-full animate-pulse inline-block"
        style="background:#4285F4;"></span>
      Frente
    </span>
  </div>

  <div
    id="viewer-shell"
    class="viewer-shell relative rounded-3xl overflow-hidden"
    style="
      border: 1px solid #DADCE0;
      box-shadow:
        0 1px 4px rgba(60,64,67,0.12),
        0 8px 24px rgba(60,64,67,0.08);
    "
  >
    <div
      class="absolute inset-0 pointer-events-none z-0"
      style="
        background: radial-gradient(ellipse 70% 45% at 50% 0%, rgba(66,133,244,0.05) 0%, transparent 70%);
      "
    >
    </div>

    <model-viewer
      id="shirt-model"
      src="/assets/models/Camisa.glb"
      alt="Vista 3D interactiva de la prenda"
      camera-controls
      touch-action="pan-y"
      camera-orbit="0deg 75deg 105%"
      min-camera-orbit="auto 30deg 80%"
      max-camera-orbit="auto 110deg 140%"
      field-of-view="28deg"
      interpolation-decay="200"
      environment-image="neutral"
      shadow-intensity="1"
      shadow-softness="0.8"
      exposure="1.05"
      style="
        width: 100%;
        height: 100%;
        display: block;
        background: transparent;
        --poster-color: transparent;
        --progress-bar-color: #4285F4;
        --progress-mask: transparent;
      "
    >
      <div slot="progress-bar" style="display:none;"></div>

      <div
        slot="poster"
        class="w-full h-full flex flex-col items-center justify-center gap-5"
        style="background: linear-gradient(160deg, #F8F9FA 0%, #EEF2FF 100%);"
      >
        <div class="relative w-14 h-14 lg:w-20 lg:h-20">
          <svg
            class="absolute inset-0 w-full h-full -rotate-90"
            viewBox="0 0 80 80"
          >
            <circle
              cx="40"
              cy="40"
              r="34"
              fill="none"
              stroke="#DADCE0"
              stroke-width="5"></circle>
          </svg>
          <svg
            class="absolute inset-0 w-full h-full -rotate-90"
            viewBox="0 0 80 80"
            style="animation: spin-slow 1s linear infinite;"
          >
            <defs>
              <linearGradient id="sgrad2" gradientTransform="rotate(90)">
                <stop offset="0%" stop-color="#4285F4"></stop>
                <stop offset="100%" stop-color="#34A853"></stop>
              </linearGradient>
            </defs>
            <circle
              cx="40"
              cy="40"
              r="34"
              fill="none"
              stroke="url(#sgrad2)"
              stroke-width="5"
              stroke-linecap="round"
              stroke-dasharray="65 148"></circle>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <svg
              class="w-6 h-6 lg:w-8 lg:h-8"
              style="color:#4285F4;"
              viewBox="0 0 100 100"
              fill="currentColor"
              fill-opacity="0.6"
              stroke="currentColor"
              stroke-width="3"
              stroke-linejoin="round"
            >
              <path
                d="M30 15 L15 35 L28 40 L28 82 L72 82 L72 40 L85 35 L70 15 L60 22 C58 28 42 28 40 22 Z"
              ></path>
            </svg>
          </div>
        </div>
        <div class="text-center">
          <p class="text-sm lg:text-base font-semibold" style="color:#5F6368;">
            Cargando modelo 3D…
          </p>
          <p class="text-xs mt-0.5" style="color:#80868B;">
            Google Cloud Experience
          </p>
        </div>
      </div>
    </model-viewer>

    <div
      id="design-3d-overlay"
      class="absolute"
      style="
        top: 38%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 35%;
        aspect-ratio: 1;
        border: 2px dashed transparent;
        border-radius: 4px;
        overflow: hidden;
        transition: top 400ms cubic-bezier(0.4,0,0.2,1), border-color 200ms ease;
        z-index: 5;
      "
    >
    </div>

    <div
      class="absolute bottom-5 left-0 right-0 flex justify-center gap-2 lg:gap-4 z-10 px-6"
    >
      <button
        id="btn-front"
        type="button"
        aria-pressed="true"
        class="view-btn view-btn-active"
        data-orbit="0deg 75deg 105%"
        data-placement="front"
        data-label="Frente"
        data-overlay-top="38%"
      >
        <svg
          class="w-3 h-3 lg:w-4 lg:h-4 shrink-0"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
            clip-rule="evenodd"></path>
        </svg>
        <span class="text-[10px] lg:text-xs">FRENTE</span>
      </button>

      <button
        id="btn-back"
        type="button"
        aria-pressed="false"
        class="view-btn"
        data-orbit="180deg 75deg 105%"
        data-placement="back"
        data-label="Espalda"
        data-overlay-top="36%"
      >
        <svg
          class="w-3 h-3 lg:w-4 lg:h-4 shrink-0"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"></path>
        </svg>
        <span class="text-[10px] lg:text-xs">ESPALDA</span>
      </button>
    </div>

    <div
      class="absolute top-4 right-4 z-10 flex items-center gap-1.5 pointer-events-none"
      style="background: rgba(255,255,255,0.85); backdrop-filter: blur(8px); border: 1px solid #DADCE0; border-radius: 20px; padding: 0.35rem 0.75rem; box-shadow: 0 1px 4px rgba(60,64,67,0.10);"
    >
      <svg
        class="w-3 h-3"
        style="color:#4285F4;"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
        ></path>
      </svg>
      <span
        class="text-[10px] lg:text-xs font-semibold hidden sm:block"
        style="color:#5F6368;">Arrastra para rotar</span
      >
    </div>
  </div>
</div>

<style>
  .viewer-shell {
    background: linear-gradient(160deg, #f8f9fa 0%, #eef2ff 100%);
    height: 280px;
    transition:
      box-shadow 300ms ease,
      border-color 300ms ease;
  }

  @media (min-width: 640px) {
    .viewer-shell {
      height: 340px;
    }
  }
  @media (min-width: 1024px) {
    .viewer-shell {
      height: 450px;
    }
  }

  .viewer-shell:hover {
    border-color: #c5c8cc !important;
    box-shadow:
      0 2px 8px rgba(60, 64, 67, 0.16),
      0 12px 32px rgba(60, 64, 67, 0.1) !important;
  }

  model-viewer {
    width: 100%;
    height: 100%;
    display: block;
    position: relative;
    z-index: 1;
  }

  .view-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans, "Google Sans", "Inter", sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.45rem 1rem;
    border-radius: 9999px;
    border: 1px solid #dadce0;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    color: #5f6368;
    cursor: pointer;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      transform 160ms ease,
      box-shadow 180ms ease,
      color 180ms ease;
    min-height: 36px;
    user-select: none;
    box-shadow: 0 1px 3px rgba(60, 64, 67, 0.1);
  }

  @media (min-width: 1024px) {
    .view-btn {
      font-size: 0.8rem;
      padding: 0.55rem 1.25rem;
      min-height: 42px;
    }
  }

  .view-btn:hover {
    background: #ffffff;
    border-color: #c5c8cc;
    color: #202124;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(60, 64, 67, 0.18);
  }
  .view-btn:active {
    transform: scale(0.97) translateY(0);
  }
  .view-btn-active {
    background: rgba(66, 133, 244, 0.1);
    border-color: rgba(66, 133, 244, 0.5);
    color: #4285f4;
    box-shadow: 0 0 0 3px rgba(66, 133, 244, 0.12);
  }
  .view-btn-active:hover {
    background: rgba(66, 133, 244, 0.15);
    border-color: rgba(66, 133, 244, 0.7);
  }
</style>

<script>
  const modelEl = document.getElementById("shirt-model") as any;
  const btnFront = document.getElementById("btn-front") as HTMLButtonElement;
  const btnBack = document.getElementById("btn-back") as HTMLButtonElement;
  const placementInput = document.getElementById(
    "placement-input",
  ) as HTMLInputElement;
  const placementBadge = document.getElementById(
    "placement-badge",
  ) as HTMLElement;
  const overlay3d = document.getElementById("design-3d-overlay") as HTMLElement;
  const viewBtns = [btnFront, btnBack];

  function switchView(btn: HTMLButtonElement) {
    const orbit = btn.dataset.orbit ?? "0deg 75deg 105%";
    const placement = btn.dataset.placement ?? "front";
    const label = btn.dataset.label ?? "Frente";
    const overlayTop = btn.dataset.overlayTop ?? "38%";
    if (modelEl) modelEl.cameraOrbit = orbit;
    placementInput.value = placement;
    const textSpan = placementBadge.querySelector(
      "[data-badge-label]",
    ) as HTMLElement | null;
    if (textSpan) textSpan.textContent = label;
    overlay3d.style.top = overlayTop;
    viewBtns.forEach((b) => {
      b.classList.remove("view-btn-active");
      b.setAttribute("aria-pressed", "false");
    });
    btn.classList.add("view-btn-active");
    btn.setAttribute("aria-pressed", "true");
    window.dispatchEvent(
      new CustomEvent("sideChanged", { detail: { side: placement } }),
    );
  }

  btnFront.addEventListener("click", () => switchView(btnFront));
  btnBack.addEventListener("click", () => switchView(btnBack));

  document.addEventListener("DOMContentLoaded", () => {
    const badge = document.getElementById("placement-badge");
    if (badge) {
      const currentText = badge.textContent?.trim() ?? "Frente";
      badge.innerHTML = `<span class="w-1.5 h-1.5 rounded-full animate-pulse inline-block" style="background:#4285F4;"></span><span data-badge-label>${currentText}</span>`;
    }
  });
</script>
