---
interface SizeOption {
  id: string;
  label: string;
}

const sizes: SizeOption[] = [
  { id: 'S', label: 'S' },
  { id: 'M', label: 'M' },
  { id: 'L', label: 'L' },
  { id: 'XL', label: 'XL' },
];
---

<div class="flex flex-col gap-4 lg:gap-6">
  <p class="text-lg lg:text-2xl font-medium px-1" style="color:#5F6368;">Talla</p>

  <div
    id="size-selector"
    role="radiogroup"
    aria-label="Talla de prenda"
    class="grid grid-cols-4 gap-3 lg:gap-5"
  >
    {sizes.map((s, i) => (
      <label
        for={`size-${s.id}`}
        class="size-card glass glass-hover rounded-xl lg:rounded-2xl cursor-pointer select-none animate-fadeInUp flex items-center justify-center"
        style={`animation-delay: ${i * 0.1}s; min-height: 56px;`}
        data-value={s.id}
      >
        <input
          type="radio"
          id={`size-${s.id}`}
          name="size"
          value={s.id}
          class="sr-only"
          required
        />
        <span class="size-label text-lg lg:text-2xl font-bold transition-colors duration-200" style="color:#5F6368;">{s.label}</span>
      </label>
    ))}
  </div>
</div>

<style>
  /* Size card base — Material white card */
  .size-card {
    border: 1px solid #DADCE0;
    background: #FFFFFF;
    transition: background 200ms ease, border-color 200ms ease, box-shadow 200ms ease, transform 180ms ease;
  }

  @media (min-width: 1024px) {
    .size-card {
      min-height: 72px !important;
    }
    .size-card:hover {
      transform: scale(1.02);
      border-color: #C5C8CC;
      box-shadow: 0 2px 8px rgba(60,64,67,0.14);
    }
  }

  /* ── Selected state — Google Blue tint ── */
  .size-card[data-selected="true"] {
    background: #E8F0FE;
    border-color: #4285F4;
    box-shadow: 0 0 0 3px rgba(66,133,244,0.15);
  }

  .size-card[data-selected="true"] .size-label {
    color: #4285F4;
    font-weight: 800;
  }
</style>

<script>
  const sizeCards = document.querySelectorAll<HTMLElement>('.size-card');
  sizeCards.forEach((card) => {
    card.addEventListener('click', () => {
      sizeCards.forEach(c => c.removeAttribute('data-selected'));
      card.setAttribute('data-selected', 'true');
      const radio = card.querySelector<HTMLInputElement>('input[type="radio"]');
      if (radio) radio.checked = true;
    });
  });
</script>
