---
import ShirtViewer3D from './ShirtViewer3D.astro';

const patches = [
  { id: 'cloud', icon: '☁️', label: 'Cloud' },
  { id: 'diamond', icon: '💎', label: 'Diamond' },
  { id: 'sun', icon: '☀️', label: 'Sun' },
  { id: 'star', icon: '⭐', label: 'Star' },
];
---

<div class="flex flex-col gap-4 lg:gap-5" id="patch-editor-root">
  <!-- Hidden input for final payload -->
  <input type="hidden" name="customization_data" id="customization-data" value='{"patches":[],"text":""}' />

  <!-- 3D GARMENT VIEWER -->
  <ShirtViewer3D />

  <!-- DRAG & DROP INVENTORY -->
  <div class="flex flex-col gap-3">
    <div class="flex justify-between items-center px-1">
      <p class="text-zinc-400 text-lg lg:text-xl font-medium">Parches (Max 4)</p>
      <span id="patch-count" class="text-xs font-bold text-violet-400 glass px-2 py-1 rounded-md">0 / 4</span>
    </div>

    <div class="grid grid-cols-4 gap-2">
      {patches.map(p => (
        <div
          draggable="true"
          class="patch-item glass glass-hover cursor-grab rounded-xl flex items-center justify-center text-3xl pb-1"
          style="aspect-ratio: 1;"
          data-type={p.label}
          data-icon={p.icon}
        >
          {p.icon}
        </div>
      ))}
    </div>

    <!-- TEXT TOOL -->
    <div class="mt-2 glass p-4 rounded-2xl flex flex-col gap-3">
      <label for="custom-text-input" class="text-zinc-400 text-sm font-medium">Texto Personalizado (1 permitido, < 10cm)</label>
      <input
        type="text"
        id="custom-text-input"
        placeholder="Ej: GOOGLE"
        maxlength="15"
        class="w-full bg-zinc-900/50 border border-zinc-700/50 rounded-xl px-4 py-3 text-white placeholder-zinc-600 focus:outline-none focus:border-violet-500 transition-colors"
      />
    </div>
  </div>
</div>

<style>
  .patch-item { border: 1px solid oklch(1 0 0 / 0.1); }
  .patch-item:active { cursor: grabbing; }
  
  /* Rendered patch on canvas */
  :global(.canvas-patch) {
    position: absolute;
    transform: translate(-50%, -50%); /* Center on cursor */
    font-size: 2rem;
    pointer-events: none; /* Let clicks pass through if needed, but wait! We might want to delete them. */
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));
  }
</style>

<script>
  // ── STATE ──
  let patchesState: any[] = [];
  let currentSide = 'front';
  let customText = '';

  // ── DOM REFS ──
  const inventoryItems = document.querySelectorAll('.patch-item');
  const textInput = document.getElementById('custom-text-input') as HTMLInputElement;
  const hiddenInput = document.getElementById('customization-data') as HTMLInputElement;
  const patchCount = document.getElementById('patch-count')!;
  
  // The dropzone is inside ShirtViewer3D
  const canvas = document.getElementById('design-3d-overlay')!;

  // ── STATE SYNC ──
  function updateState() {
    customText = textInput.value;
    hiddenInput.value = JSON.stringify({
      patches: patchesState,
      text: customText
    });
    patchCount.textContent = `${patchesState.length} / 4`;
    renderCanvas();
  }

  // ── RENDER CANVAS BASE ON SIDE ──
  function renderCanvas() {
    canvas.innerHTML = '';
    const visiblePatches = patchesState.filter(p => p.side === currentSide);
    
    visiblePatches.forEach(p => {
      const el = document.createElement('div');
      el.className = 'canvas-patch';
      el.textContent = p.icon;
      el.style.left = `${p.x}%`;
      el.style.top = `${p.y}%`;
      canvas.appendChild(el);
    });
  }

  // Listen for side changes from ShirtViewer3D
  window.addEventListener('sideChanged', (e: any) => {
    currentSide = e.detail.side;
    renderCanvas();
  });

  textInput.addEventListener('input', () => updateState());

  // ── DRAG & DROP LOGIC ──
  inventoryItems.forEach(item => {
    item.addEventListener('dragstart', (e: any) => {
      if (patchesState.length >= 4) {
        e.preventDefault();
        alert('Límite de 4 parches alcanzado.');
        return;
      }
      e.dataTransfer.setData('text/plain', JSON.stringify({
        type: item.getAttribute('data-type'),
        icon: item.getAttribute('data-icon')
      }));
      canvas.style.borderColor = 'oklch(0.65 0.22 270 / 0.8)';
    });
    
    item.addEventListener('dragend', () => {
      canvas.style.borderColor = 'transparent';
    });
  });

  canvas.addEventListener('dragover', (e) => {
    e.preventDefault(); // Necessary to allow dropping
    e.dataTransfer!.dropEffect = 'copy';
  });

  canvas.addEventListener('drop', (e) => {
    e.preventDefault();
    canvas.style.borderColor = 'transparent';
    
    if (patchesState.length >= 4) return;

    try {
      const data = JSON.parse(e.dataTransfer!.getData('text/plain'));
      
      // Calculate coordinates relative to canvas (0-100%)
      const rect = canvas.getBoundingClientRect();
      let x = ((e.clientX - rect.left) / rect.width) * 100;
      let y = ((e.clientY - rect.top) / rect.height) * 100;
      
      // Clamp bounds
      x = Math.max(0, Math.min(100, x));
      y = Math.max(0, Math.min(100, y));

      patchesState.push({
        id: Date.now().toString(),
        type: data.type,
        icon: data.icon,
        x: Math.round(x * 10) / 10, // 1 decimal
        y: Math.round(y * 10) / 10,
        side: currentSide
      });
      
      updateState();
    } catch (err) {
      console.error('Invalid drop', err);
    }
  });
</script>
