---
import ShirtViewer3D from './ShirtViewer3D.astro';
import totebagCremaImg from '../assets/models/TotebagCrema.png';
import totebagNegraImg from '../assets/models/TotebagNegra.png';

interface Props {
  isPreview?: boolean;
  garmentId?: string;
}
const { isPreview = false, garmentId = '' } = Astro.props;

const isTotebag = garmentId.includes('totebag');
const totebagSrc = garmentId === 'totebag-crema' ? totebagCremaImg.src : totebagNegraImg.src;

const patches = [
  { id: 'cloud',   icon: '☁️', label: 'Cloud'   },
  { id: 'diamond', icon: '💎', label: 'Diamond' },
  { id: 'sun',     icon: '☀️', label: 'Sun'     },
  { id: 'star',    icon: '⭐', label: 'Star'    },
];
---

<div class="flex flex-col gap-4 lg:gap-5" id="patch-editor-root">
  <!-- Hidden inputs for final payload -->
  <input type="hidden" name="customization_data" id="customization-data" value='{"patches":[],"text":""}' />
  <input type="hidden" id="placement-input" name="placement" value="front" />

  {isTotebag ? (
    /* ── TOTE BAG VIEWER ─────────────────────────────────────── */
    <div class="flex flex-col gap-3 lg:gap-4">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 px-6 lg:px-10 pt-4">
        <div class="flex flex-col min-w-0">
          <p class="text-lg lg:text-2xl font-bold leading-tight tracking-tight" style="color:#202124;">
            Personaliza tu tote bag
          </p>
          <p class="text-[11px] lg:text-base mt-1" style="color:#5F6368;">
            Escribe tu nombre · verás la vista previa en tiempo real
          </p>
        </div>
        <span class="flex items-center gap-2 px-4 py-2 rounded-full text-[10px] lg:text-xs font-bold uppercase tracking-widest w-fit shrink-0 shadow-sm"
          style="background: rgba(66,133,244,0.10); border: 1px solid rgba(66,133,244,0.35); color: #4285F4;">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse inline-block" style="background:#4285F4;"></span>
          Vista previa
        </span>
      </div>

      <div class="tote-shell">
        <div
          class="absolute inset-0 pointer-events-none z-0"
          style="background: radial-gradient(ellipse 70% 45% at 50% 0%, rgba(66,133,244,0.05) 0%, transparent 70%);"
        ></div>
        <div class="tote-img-wrap">
          <img src={totebagSrc} alt="Tote bag" class="tote-img" />
          <div id="tote-text-overlay" class="tote-text-overlay" aria-hidden="true"></div>
        </div>
      </div>

      {!isPreview && (
        <div class="px-6 lg:px-10 pb-2">
          <div class="p-4 rounded-2xl flex flex-col gap-3" style="background:#F8F9FA; border:1px solid #DADCE0;">
            <label for="custom-text-input"
                   class="text-xs lg:text-sm font-medium uppercase tracking-widest"
                   style="color:#80868B;">
              Nombre <span style="font-weight:400;">(máx 15 caracteres)</span>
            </label>
            <input
              type="text"
              id="custom-text-input"
              placeholder="Ej: GOOGLE"
              maxlength="15"
              class="custom-text-input"
            />
          </div>
        </div>
      )}
    </div>
  ) : (
    /* ── SHIRT VIEWER ────────────────────────────────────────── */
    <div>
      <div class="relative">
        <ShirtViewer3D isPreview={isPreview} />
        {isPreview && (
          <div class="absolute inset-0 z-[100] cursor-default" style="background: transparent;" aria-hidden="true"></div>
        )}
      </div>

      {!isPreview && (
        <div class="flex flex-col gap-3 px-6 lg:px-10 pb-2 mt-3">
          <div class="flex justify-between items-center px-1">
            <p class="text-sm lg:text-base font-semibold" style="color:#202124;">Parches <span style="color:#80868B;font-weight:400;">(Max 4)</span></p>
            <span id="patch-count"
              class="text-xs font-bold px-2 py-1 rounded-full"
              style="background:rgba(66,133,244,0.10); color:#4285F4; border:1px solid rgba(66,133,244,0.25);"
            >0 / 4</span>
          </div>

          <div class="grid grid-cols-4 gap-2">
            {patches.map(p => (
              <div
                class="patch-item"
                style="touch-action: none; aspect-ratio: 1;"
                data-type={p.label}
                data-icon={p.icon}
                role="button"
                tabindex="0"
                aria-label={`Parche: ${p.label}`}
              >
                {p.icon}
              </div>
            ))}
          </div>

          <div class="mt-2 p-4 rounded-2xl flex flex-col gap-3"
               style="background:#F8F9FA; border:1px solid #DADCE0;">
            <label for="custom-text-input"
                   class="text-xs lg:text-sm font-medium uppercase tracking-widest"
                   style="color:#80868B;">
              Texto Personalizado <span style="font-weight:400;">(1 • máx 15 caracteres)</span>
            </label>
            <input
              type="text"
              id="custom-text-input"
              placeholder="Ej: GOOGLE"
              maxlength="15"
              class="custom-text-input"
            />
          </div>
        </div>
      )}
    </div>
  )}
</div>

<style>
  /* ── Tote bag shell ── */
  .tote-shell {
    position: relative;
    background: linear-gradient(160deg, #f8f9fa 0%, #eef2ff 100%);
    border: 1px solid #DADCE0;
    border-radius: 1.5rem;
    overflow: hidden;
    height: 320px;
    box-shadow: 0 1px 4px rgba(60,64,67,0.12), 0 8px 24px rgba(60,64,67,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 1px;
  }
  @media (min-width: 640px)  { .tote-shell { height: 400px; } }
  @media (min-width: 1024px) { .tote-shell { height: 520px; } }

  .tote-img-wrap {
    position: relative;
    height: 88%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tote-img {
    height: 100%;
    width: auto;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.12));
  }
  .tote-text-overlay {
    position: absolute;
    bottom: 22%;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Google Sans', 'Inter', sans-serif;
    font-size: clamp(0.7rem, 2.5vw, 1.2rem);
    font-weight: 800;
    color: #1a1a2e;
    white-space: nowrap;
    max-width: 60%;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: center;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    pointer-events: none;
    text-shadow: 0 0 10px rgba(255,255,255,0.9), 0 1px 0 rgba(255,255,255,0.6);
    min-height: 1.5em;
  }

  /* ── Patch inventory items ── */
  .patch-item {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    padding-bottom: 2px;
    border-radius: 0.75rem;
    border: 1px solid #DADCE0;
    background: #FFFFFF;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
    will-change: transform;
  }
  .patch-item:hover {
    border-color: rgba(66,133,244,0.5);
    box-shadow: 0 2px 8px rgba(66,133,244,0.15);
  }
  .patch-item.is-dragging {
    cursor: grabbing;
    opacity: 0.4;
  }

  /* ── Floating ghost clone ── */
  :global(.patch-ghost) {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    transform: translate(-50%, -50%) scale(1.15);
    filter: drop-shadow(0 8px 16px rgba(66,133,244,0.40)) drop-shadow(0 2px 4px rgba(0,0,0,0.25));
    transition: transform 80ms ease;
    will-change: left, top, transform;
  }

  /* ── Placed patches inside the canvas overlay ── */
  :global(.canvas-patch) {
    position: absolute;
    transform: translate(-50%, -50%);
    font-size: clamp(1.25rem, 3.5vw, 2rem);
    pointer-events: none;
    filter: drop-shadow(0 3px 6px rgba(0,0,0,0.35));
    transition: transform 200ms cubic-bezier(0.34,1.56,0.64,1);
    animation: patch-land 220ms cubic-bezier(0.34,1.56,0.64,1) both;
  }
  @keyframes patch-land {
    from { transform: translate(-50%, -50%) scale(0.5); opacity: 0; }
    to   { transform: translate(-50%, -50%) scale(1);   opacity: 1; }
  }

  /* ── Canvas drop zone highlight ── */
  :global(#design-3d-overlay.drag-over) {
    border-color: rgba(66,133,244,0.7) !important;
    background: rgba(66,133,244,0.06);
  }

  /* ── Text printed on shirt ── */
  :global(.canvas-text) {
    position: absolute;
    bottom: 8%;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Google Sans', 'Inter', sans-serif;
    font-size: clamp(0.45rem, 1.8vw, 0.85rem);
    font-weight: 800;
    color: #1a1a2e;
    white-space: nowrap;
    max-width: 94%;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: center;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    pointer-events: none;
    text-shadow: 0 0 8px rgba(255,255,255,0.8), 0 1px 0 rgba(255,255,255,0.5);
  }

  /* ── Empty state hint inside drop zone ── */
  :global(.canvas-empty-hint) {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    pointer-events: none;
    color: #4285F4;
    opacity: 0.6;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-align: center;
    text-shadow: 0 0 8px rgba(255,255,255,0.9);
  }

  /* ── Custom text input ── */
  .custom-text-input {
    width: 100%;
    background: #FFFFFF;
    border: 1px solid #DADCE0;
    border-radius: 0.75rem;
    padding: 0.65rem 1rem;
    font-size: 0.9rem;
    color: #202124;
    outline: none;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }
  .custom-text-input::placeholder { color: #BDC1C6; }
  .custom-text-input:focus {
    border-color: #4285F4;
    box-shadow: 0 0 0 3px rgba(66,133,244,0.18);
  }
</style>

<script is:inline define:vars={{ isPreview, isTotebag }}>
(function () {
  // ── STATE
  var patchesState = [];
  var currentSide  = 'front';

  // ── DOM REFS
  var textInput      = document.getElementById('custom-text-input');
  var hiddenInput    = document.getElementById('customization-data');
  var patchCount     = document.getElementById('patch-count');
  var canvas         = document.getElementById('design-3d-overlay');
  var toteOverlay    = document.getElementById('tote-text-overlay');
  var inventoryItems = Array.from(document.querySelectorAll('.patch-item'));

  // ── STATE SYNC
  function updateState() {
    var text = textInput ? textInput.value : '';
    var data = { patches: patchesState, text: text };
    if (hiddenInput) hiddenInput.value = JSON.stringify(data);
    sessionStorage.setItem('currentCustomization', JSON.stringify(data));

    if (isTotebag) {
      if (toteOverlay) toteOverlay.textContent = text.trim().toUpperCase();
    } else {
      if (patchCount) patchCount.textContent = patchesState.length + ' / 4';
      renderCanvas();
    }
  }

  function renderCanvas() {
    if (!canvas) return;
    canvas.innerHTML = '';
    var patchesForSide = patchesState.filter(function (p) { return p.side === currentSide; });
    var text = textInput ? textInput.value.trim() : '';

    if (patchesForSide.length === 0 && !text) {
      var hint = document.createElement('div');
      hint.className = 'canvas-empty-hint';
      hint.innerHTML =
        '<svg style="width:1.3rem;height:1.3rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16m8-8H4"/></svg>' +
        '<span>ARRASTRA AQUÍ</span>';
      canvas.appendChild(hint);
      return;
    }

    patchesForSide.forEach(function (p) {
      var el = document.createElement('div');
      el.className   = 'canvas-patch';
      el.textContent = p.icon;
      el.style.left  = p.x + '%';
      el.style.top   = p.y + '%';
      canvas.appendChild(el);
    });

    if (text) {
      var textEl = document.createElement('div');
      textEl.className   = 'canvas-text';
      textEl.textContent = text;
      canvas.appendChild(textEl);
    }
  }

  // ── INIT
  function init() {
    var saved = sessionStorage.getItem('currentCustomization');
    if (saved) {
      try {
        var data = JSON.parse(saved);
        patchesState = data.patches || [];
        if (textInput && data.text) {
          textInput.value = data.text;
          if (isTotebag && toteOverlay) toteOverlay.textContent = data.text.trim().toUpperCase();
        }
      } catch (e) {}
    }
    if (!isTotebag) renderCanvas();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // ── LIVE TEXT UPDATE
  if (textInput) {
    textInput.addEventListener('input', function () { updateState(); });
  }

  // ── SIDE CHANGE (shirt only)
  window.addEventListener('sideChanged', function (e) {
    currentSide = e.detail.side;
    renderCanvas();
  });

  // ── DRAG ENGINE (shirt only, skip in preview or tote bag)
  if (!isPreview && !isTotebag) {
    var session = null;

    function createGhost(icon) {
      var g = document.createElement('div');
      g.className   = 'patch-ghost';
      g.textContent = icon;
      document.body.appendChild(g);
      return g;
    }

    function positionGhost(ghost, x, y) {
      ghost.style.left = x + 'px';
      ghost.style.top  = y + 'px';
    }

    function cleanupSession() {
      if (!session) return;
      session.ghost.remove();
      session.item.classList.remove('is-dragging');
      if (canvas) canvas.classList.remove('drag-over');
      if (session.rafId !== null) cancelAnimationFrame(session.rafId);
      session = null;
    }

    function onPointerMove(e) {
      if (!session) return;
      session.px = e.clientX;
      session.py = e.clientY;

      if (canvas) {
        var under = document.elementFromPoint(e.clientX, e.clientY);
        if (under && canvas.contains(under)) {
          canvas.classList.add('drag-over');
        } else {
          canvas.classList.remove('drag-over');
        }
      }

      if (!session.rafPending) {
        session.rafPending = true;
        session.rafId = requestAnimationFrame(function () {
          if (session) {
            positionGhost(session.ghost, session.px, session.py);
            session.rafPending = false;
          }
        });
      }
    }

    function onPointerUp(e) {
      if (!session) return;

      if (canvas) {
        var rect = canvas.getBoundingClientRect();
        var over =
          e.clientX >= rect.left && e.clientX <= rect.right &&
          e.clientY >= rect.top  && e.clientY <= rect.bottom;

        if (over && patchesState.length < 4) {
          var x = ((e.clientX - rect.left) / rect.width)  * 100;
          var y = ((e.clientY - rect.top)  / rect.height) * 100;
          x = Math.max(2, Math.min(98, x));
          y = Math.max(2, Math.min(98, y));
          patchesState.push({
            id:   Date.now().toString(),
            type: session.type,
            icon: session.icon,
            x:    Math.round(x * 10) / 10,
            y:    Math.round(y * 10) / 10,
            side: currentSide,
          });
          updateState();
        } else if (patchesState.length >= 4 && over) {
          canvas.animate(
            [{ transform: 'translateX(-4px)' }, { transform: 'translateX(4px)' }, { transform: 'translateX(0)' }],
            { duration: 250, iterations: 2, easing: 'ease-in-out' }
          );
        }
      }

      cleanupSession();
      document.removeEventListener('pointermove',   onPointerMove);
      document.removeEventListener('pointerup',     onPointerUp);
      document.removeEventListener('pointercancel', onPointerCancel);
    }

    function onPointerCancel() {
      cleanupSession();
      document.removeEventListener('pointermove',   onPointerMove);
      document.removeEventListener('pointerup',     onPointerUp);
      document.removeEventListener('pointercancel', onPointerCancel);
    }

    inventoryItems.forEach(function (item) {
      item.addEventListener('pointerdown', function (e) {
        if (e.button !== 0 && e.pointerType === 'mouse') return;
        if (patchesState.length >= 4) {
          item.animate(
            [{ transform: 'scale(1)' }, { transform: 'scale(0.88)' }, { transform: 'scale(1)' }],
            { duration: 300, easing: 'ease-in-out' }
          );
          return;
        }

        e.preventDefault();

        var icon = item.getAttribute('data-icon') || '?';
        var type = item.getAttribute('data-type') || '';

        item.setPointerCapture(e.pointerId);

        var ghost = createGhost(icon);
        positionGhost(ghost, e.clientX, e.clientY);
        item.classList.add('is-dragging');

        session = {
          item: item, ghost: ghost, type: type, icon: icon,
          px: e.clientX, py: e.clientY,
          rafId: null, rafPending: false,
        };

        document.addEventListener('pointermove',   onPointerMove,   { passive: true });
        document.addEventListener('pointerup',     onPointerUp);
        document.addEventListener('pointercancel', onPointerCancel);
      });
    });
  }
})();
</script>
