---
import { supabase } from '../lib/supabase';

let garments = [];
try {
  const { data, error } = await supabase
    .from('products')
    .select('id, name, description, image_url')
    .limit(4);
    
  if (error) throw error;
  garments = data || [];
} catch (e) {
  console.error("Supabase Error:", e);
}

// Fallback visual
if (garments.length === 0) {
  garments = [
    { id: 'tshirt-black', name: 'Camiseta Negra', description: '100% algodón' },
    { id: 'tshirt-white', name: 'Camiseta Blanca', description: '100% algodón' },
    { id: 'totebag-crema', name: 'Totebag Crema', description: '100% algodón' },
    { id: 'totebag-black', name: 'Totebag Negra', description: '100% algodón' },
  ];
}
---

<div class="flex flex-col gap-4 lg:gap-6 font-['Montserrat']">
  <p class="text-neutral-400 text-3xl md:text-4xl font-medium px-1 flex flex-col gap-2">
    Paso 1:
    <span class="text-neutral-500 text-xl font-regular">¿Qué prenda deseas llevar?</span>
  </p>

  <div
    id="garment-selector"
    role="radiogroup"
    aria-label="Tipo de prenda"
    class="grid grid-cols-2 gap-4 lg:gap-6 py-3"
  >
    {garments.map((g, i) => (
      <label
        for={`garment-${g.id}`}
        class="product-card group relative w-full h-56 bg-stone-50 rounded-3xl flex flex-col items-center justify-end pb-3 transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg border-2 border-transparent cursor-pointer animate-fadeInUp"
        style={`animation-delay: ${i * 0.1}s`}
      >
        <input
          type="radio"
          id={`garment-${g.id}`}
          name="garmentType"
          value={g.id}
          class="sr-only garment-radio"
          required
        />
        
        <!-- Mockup / Imagen -->
        <div class="flex-1 w-full flex items-center justify-center p-4">
          {g.image_url ? (
            <img src={g.image_url} alt={g.name} class="max-h-full object-contain drop-shadow-md" />
          ) : (
            <div class="w-20 h-20 text-zinc-300 flex items-center justify-center transition-colors group-hover:text-zinc-400">
               <svg viewBox="0 0 100 100" fill="none" class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
                <path d="M30 15 L15 35 L28 40 L28 82 L72 82 L72 40 L85 35 L70 15 L60 22 C58 28 42 28 40 22 Z" stroke="currentColor" stroke-width="3" stroke-linejoin="round" fill="currentColor" fill-opacity="0.1"/>
               </svg>
            </div>
          )}
        </div>

        <!-- Meta (Nombre y Descripción) -->
        <div class="w-[90%] bg-white shadow-sm rounded-2xl py-2 px-2 flex flex-col items-center transition-colors group-hover:bg-blue-50 meta-box">
          <span class="text-blue-500 text-xs md:text-sm font-medium text-center leading-tight">{g.name}</span>
          <span class="text-neutral-400 text-[10px] md:text-xs font-light tracking-wide">{g.description}</span>
        </div>

        <!-- Indicador de selección oculto -->
        <div class="selection-ring absolute inset-0 rounded-3xl border-4 border-[#4285F4] opacity-0 transition-opacity duration-300 pointer-events-none"></div>
      </label>
    ))}
  </div>
</div>

<style>
  /* Selected interactions via CSS :has */
  .product-card:has(input:checked) {
    transform: scale(1.02);
  }
  .product-card:has(input:checked) .meta-box {
    background-color: #eff6ff;
  }
  .product-card:has(input:checked) .selection-ring {
    opacity: 1;
  }
</style>

<script>
  // Add quick animation pop on selection change independent of the CSS :has
  const radios = document.querySelectorAll('.garment-radio');
  radios.forEach(radio => {
    radio.addEventListener('change', (e) => {
      const parent = (e.target as HTMLElement).closest('.product-card');
      if(parent) {
        parent.animate([
          { transform: 'scale(0.95)' },
          { transform: 'scale(1.02)' }
        ], { duration: 250, easing: 'cubic-bezier(0.175, 0.885, 0.32, 1.275)' });
      }
    });
  });
</script>
