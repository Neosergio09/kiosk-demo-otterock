---
interface GarmentOption {
  id: string;
  label: string;
  description: string;
  icon: string;
}

const garments: GarmentOption[] = [
  {
    id: 'tshirt',
    label: 'T-Shirt',
    description: 'Algodón 100% premium',
    icon: `<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M30 15 L15 35 L28 40 L28 82 L72 82 L72 40 L85 35 L70 15 L60 22 C58 28 42 28 40 22 Z"
        stroke="currentColor" stroke-width="3" stroke-linejoin="round" fill="currentColor" fill-opacity="0.08"/>
    </svg>`
  }
];
---

<div class="flex flex-col gap-4 lg:gap-6">
  <p class="text-zinc-400 text-lg lg:text-2xl font-medium px-1">Selecciona tu prenda</p>

  <!--
    Mobile : 3-column icon grid
    Totem  : vertical full-width cards
  -->
  <div
    id="garment-selector"
    role="radiogroup"
    aria-label="Tipo de prenda"
    class="garment-grid"
  >
    {garments.map((g, i) => (
      <label
        for={`garment-${g.id}`}
        class="garment-card glass glass-hover rounded-2xl lg:rounded-3xl cursor-pointer select-none animate-fadeInUp"
        style={`animation-delay: ${i * 0.1}s`}
        data-value={g.id}
      >
        <input
          type="radio"
          id={`garment-${g.id}`}
          name="garmentType"
          value={g.id}
          class="sr-only"
          required
        />

        <!-- Mobile layout: icon + label stacked -->
        <div class="mobile-card flex flex-col items-center gap-2 p-4 text-center">
          <div class="garment-icon w-14 h-14 text-zinc-400 transition-colors duration-300" set:html={g.icon} />
          <span class="garment-label text-sm font-bold text-white leading-tight">{g.label}</span>
          <span class="text-xs text-zinc-500 leading-tight">{g.description}</span>
          <!-- Mobile check dot -->
          <div class="garment-check-dot w-4 h-4 rounded-full border-2 border-zinc-600 mt-1 transition-all duration-300"></div>
        </div>

        <!-- Totem/Desktop layout: horizontal row -->
        <div class="desktop-card hidden items-center gap-8 px-8 py-0">
          <div class="garment-icon w-20 h-20 lg:w-24 lg:h-24 shrink-0 text-zinc-400 transition-colors duration-300" set:html={g.icon} />
          <div class="flex flex-col gap-1 flex-1">
            <span class="garment-label text-2xl lg:text-3xl font-bold text-white tracking-tight leading-none">{g.label}</span>
            <span class="text-base lg:text-xl text-zinc-500">{g.description}</span>
          </div>
          <div class="garment-check w-9 h-9 lg:w-10 lg:h-10 rounded-full border-2 border-zinc-700 flex items-center justify-center transition-all duration-300 shrink-0">
            <svg class="w-4 h-4 lg:w-5 lg:h-5 opacity-0 transition-opacity duration-200" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
          </div>
        </div>
      </label>
    ))}
  </div>
</div>

<style>
  /* ── Grid: 3 cols on mobile, 1 col (tall cards) on lg ── */
  .garment-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 1024px) {
    .garment-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  /* ── Card base ── */
  .garment-card {
    border: 1px solid oklch(1 0 0 / 0.07);
    transition: background 250ms ease, border-color 250ms ease, box-shadow 250ms ease, transform 200ms ease;
    min-height: 100px;
  }

  @media (min-width: 1024px) {
    .garment-card {
      min-height: 110px;
    }
    .garment-card:hover {
      transform: scale(1.015);
      border-color: oklch(1 0 0 / 0.13);
    }
    /* Hide mobile layout, show desktop row */
    .garment-card .mobile-card  { display: none; }
    .garment-card .desktop-card { display: flex; }
  }

  /* ── Selected state ── */
  .garment-card[data-selected="true"] {
    background: oklch(0.65 0.22 270 / 0.12);
    border-color: oklch(0.65 0.22 270 / 0.5);
    box-shadow: 0 0 30px oklch(0.65 0.22 270 / 0.2);
  }

  .garment-card[data-selected="true"] .garment-icon {
    color: oklch(0.75 0.2 270);
  }

  /* Desktop checkmark ring */
  .garment-card[data-selected="true"] .garment-check {
    background: linear-gradient(135deg, oklch(0.65 0.22 270), oklch(0.7 0.2 310));
    border-color: transparent;
    box-shadow: 0 0 16px oklch(0.65 0.22 270 / 0.5);
  }
  .garment-card[data-selected="true"] .garment-check svg { opacity: 1; }

  /* Mobile check dot */
  .garment-card[data-selected="true"] .garment-check-dot {
    background: linear-gradient(135deg, oklch(0.65 0.22 270), oklch(0.7 0.2 310));
    border-color: transparent;
    box-shadow: 0 0 8px oklch(0.65 0.22 270 / 0.6);
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.garment-card');
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      cards.forEach(c => c.removeAttribute('data-selected'));
      card.setAttribute('data-selected', 'true');
      const radio = card.querySelector<HTMLInputElement>('input[type="radio"]');
      if (radio) radio.checked = true;
    });
  });
</script>
