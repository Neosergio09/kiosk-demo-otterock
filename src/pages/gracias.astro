---
import "../styles/global.css";

import recurso1Url from "../assets/models/Recurso 1.svg?url";
import recurso3Url from "../assets/models/Recurso 3.svg?url";
import googleCloudLogoUrl from "../assets/models/Google Cloud.svg?url";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#FFFFFF" />
    <title>¡Gracias! — Google Cloud Day 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="thank-body">
    <!-- DECORATIVE CORNERS -->
    <div class="corner corner-tr" aria-hidden="true">
      <img src={recurso3Url} alt="" class="corner-img" />
    </div>
    <div class="corner corner-ml" aria-hidden="true">
      <img src={recurso1Url} alt="" class="corner-img" />
    </div>

    <main class="thank-card">
      <!-- GOOGLE DOTS -->
      <div class="dot-row" aria-hidden="true">
        <span class="dot" style="background:#4285F4; animation-delay: 0s;"></span>
        <span class="dot" style="background:#EA4335; animation-delay: 0.1s;"></span>
        <span class="dot" style="background:#FBBC04; animation-delay: 0.2s;"></span>
        <span class="dot" style="background:#34A853; animation-delay: 0.3s;"></span>
      </div>

      <!-- LOGO -->
      <div class="logo-wrap animate-slide-up" style="animation-delay:.05s;">
        <img src={googleCloudLogoUrl} alt="Google Cloud" class="gc-logo" />
      </div>

      <!-- MAIN MESSAGE -->
      <header class="hero-text animate-slide-up" style="animation-delay:.15s;">
        <h1 class="greeting">¡Gracias por participar!</h1>
        <p class="subtitle mt-3">
          Fue un placer crear algo único contigo en<br />
          <strong style="color:#4285F4; font-weight:700;">Google Cloud Day 2026</strong>
        </p>
      </header>

      <!-- CONFETTI BADGES -->
      <div class="badges animate-slide-up" style="animation-delay:.25s;">
        <span class="badge badge-blue">☁️ Cloud</span>
        <span class="badge badge-green">🚀 Innovación</span>
        <span class="badge badge-yellow">✨ Tu prenda</span>
        <span class="badge badge-red">❤️ Hecho con amor</span>
      </div>

      <!-- COUNTDOWN MESSAGE -->
      <p class="countdown-msg animate-slide-up" style="animation-delay:.35s;">
        Volviendo al inicio en <span id="countdown" class="countdown-num">60</span>s
        para el siguiente creador…
      </p>

      <!-- CTA BUTTON -->
      <footer class="animate-slide-up" style="animation-delay:.45s;">
        <a href="/" id="restart-btn" class="cta-btn">
          Empezar de nuevo
          <svg class="cta-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </footer>
    </main>
  </body>
</html>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html { background: #ffffff; }

  .thank-body {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    font-family: "Google Sans", "Inter", sans-serif;
    overflow: hidden;
    position: relative;
  }

  .corner {
    position: fixed;
    pointer-events: none;
    z-index: 2;
  }
  .corner-img { width: 100%; height: auto; display: block; }
  .corner-tr { top: 5%; right: 5%; width: clamp(200px, 20vw, 320px); z-index: 15; }
  .corner-ml { top: 35%; left: 8%; width: clamp(90px, 10vw, 120px); z-index: 15; }

  .thank-card {
    position: relative;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.25rem, 3vh, 2rem);
    padding: clamp(2rem, 5vh, 4rem) 1.5rem;
    max-width: 720px;
    width: 100%;
    text-align: center;
  }

  /* Google dots */
  .dot-row { display: flex; align-items: center; gap: 14px; }
  .dot {
    display: block;
    width: 20px; height: 20px;
    border-radius: 50%;
    animation: dot-jump 1.4s infinite ease-in-out;
    will-change: transform;
  }
  @keyframes dot-jump {
    0%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-14px); }
  }

  /* Logo */
  .logo-wrap { display: flex; align-items: center; justify-content: center; }
  .gc-logo { height: clamp(2.5rem, 6vw, 4rem); width: auto; object-fit: contain; }

  /* Typography */
  .hero-text { display: flex; flex-direction: column; align-items: center; }
  .greeting {
    font-size: clamp(2.5rem, 9vw, 4.5rem);
    font-weight: 700;
    color: #202124;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .subtitle {
    font-size: clamp(1.1rem, 3.5vw, 1.6rem);
    color: #5f6368;
    line-height: 1.5;
  }

  /* Badges */
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: clamp(0.8rem, 2vw, 1rem);
    font-weight: 600;
    padding: 0.45rem 1rem;
    border-radius: 9999px;
    border: 1px solid;
  }
  .badge-blue  { background: rgba(66,133,244,0.10);  border-color: rgba(66,133,244,0.30);  color: #4285F4; }
  .badge-green { background: rgba(52,168,83,0.10);   border-color: rgba(52,168,83,0.30);   color: #34A853; }
  .badge-yellow{ background: rgba(251,188,4,0.12);   border-color: rgba(251,188,4,0.35);   color: #B8860B; }
  .badge-red   { background: rgba(234,67,53,0.10);   border-color: rgba(234,67,53,0.30);   color: #EA4335; }

  /* Countdown */
  .countdown-msg {
    font-size: clamp(0.85rem, 2.5vw, 1.1rem);
    color: #80868B;
    font-weight: 500;
  }
  .countdown-num {
    font-variant-numeric: tabular-nums;
    color: #4285F4;
    font-weight: 700;
    font-size: 1.15em;
  }

  /* CTA */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: #4285f4;
    color: #ffffff;
    border-radius: 9999px;
    font-size: clamp(1rem, 3vw, 1.4rem);
    font-weight: 600;
    padding: clamp(0.9rem, 2vh, 1.1rem) clamp(2.5rem, 8vw, 5rem);
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(66,133,244,0.4);
    transition: all 200ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
    font-family: "Google Sans", "Inter", sans-serif;
  }
  .cta-btn:hover {
    background: #3367d6;
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 10px 32px rgba(66,133,244,0.5);
  }
  .cta-arrow { width: 1.4rem; height: 1.4rem; transition: transform 200ms ease; }
  .cta-btn:hover .cta-arrow { transform: translateX(6px); }

  /* Slide-up animation */
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-slide-up {
    animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
</style>

<script is:inline>
  // Auto-redirect countdown (60 seconds)
  var seconds = 60;
  var el = document.getElementById('countdown');
  var interval = setInterval(function () {
    seconds--;
    if (el) el.textContent = seconds;
    if (seconds <= 0) {
      clearInterval(interval);
      window.location.href = '/';
    }
  }, 1000);

  // If user clicks the button, cancel the timer
  var btn = document.getElementById('restart-btn');
  if (btn) {
    btn.addEventListener('click', function () {
      clearInterval(interval);
    });
  }
</script>
