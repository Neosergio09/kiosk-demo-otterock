---
import "../styles/global.css";

// ── Asset imports ──────
import recurso1Url from "../assets/models/Recurso 1.svg?url";
import recurso3Url from "../assets/models/Recurso 3.svg?url";
import gcLogoUrl from "../assets/models/google cloud logo.svg?url";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="description"
      content="Bienvenido al Kiosk de personalización — Google Cloud Day 2026"
    />
    <meta name="theme-color" content="#FFFFFF" />
    <title>Bienvenido — Google Cloud Day</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Inter:wght@300;400;500;600;700;800;900&family=Roboto+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="welcome-body">
    <div class="corner corner-tr" aria-hidden="true">
      <img src={recurso3Url} alt="" class="corner-img" />
    </div>

    <div class="corner corner-ml" aria-hidden="true">
      <img src={recurso1Url} alt="" class="corner-img" />
    </div>

    <div class="hero-svg-container" aria-hidden="true">
      <div class="hero-anim-wrapper w-full h-full">
        <svg
          id="Capa_2"
          data-name="Capa 2"
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
          viewBox="0 0 765.99 723.73"
        >
          <defs>
            <style>
              .cls-1 {
                fill: #4285f4;
              }
              .cls-2 {
                clip-path: url(#clippath-1);
              }
              .cls-3 {
                clip-path: url(#clippath);
              }
            </style>
            <clipPath id="clippath">
              <path
                class="cls-1"
                d="M.06,488.49l-.03-.58c-.89-19.53,14.22-36.07,33.74-36.96,19.45-.89,35.94,14.09,36.95,33.5l.1,1.93.02.45L.06,488.49Z"
              ></path>
            </clipPath>
            <clipPath id="clippath-1">
              <path
                class="cls-1"
                d="M513.08,71.44l-.41.03-.67.05c-19.5,1.47-36.5-13.14-37.97-32.64-1.47-19.5,13.07-36.49,32.57-37.96l.61-.05,5.87,70.57Z"
              ></path>
            </clipPath>
          </defs>
          <g id="Capa_1-2" data-name="Capa 1">
            <g>
              <g>
                <path
                  class="cls-1"
                  d="M.06,488.49l-.03-.58c-.89-19.53,14.22-36.07,33.74-36.96,19.45-.89,35.94,14.09,36.95,33.5l.1,1.93.02.45L.06,488.49Z"
                ></path>
                <g class="cls-3">
                  <g id="parallax-img-1">
                    <image
                      width="78"
                      height="146"
                      transform="translate(-6.43 344.48)"
                      xlink:href="data:image/png;base64,"
                    />
                  </g>
                </g>
              </g>
              <image
                width="767"
                height="725"
                transform="translate(-.43 -.52)"
                xlink:href="data:image/png;base64,"
              />
              <g class="cls-2">
                <image
                  id="parallax-img-2"
                  width="150"
                  height="82"
                  transform="translate(364.57 .48)"
                  xlink:href="data:image/png;base64,"
                />
              </g>
            </g>
          </g>
        </svg>
      </div>
    </div>

    <main class="welcome-card">
      <div class="dot-row" aria-hidden="true">
        <span class="dot" style="background:#4285F4; animation-delay: 0s;"
        ></span>
        <span class="dot" style="background:#EA4335; animation-delay: 0.1s;"
        ></span>
        <span class="dot" style="background:#FBBC04; animation-delay: 0.2s;"
        ></span>
        <span class="dot" style="background:#34A853; animation-delay: 0.3s;"
        ></span>
      </div>

      <section class="hero-text">
        <h1 class="greeting animate-slide-up">¡Hola! Bienvenido</h1>
        <p class="subtitle animate-slide-up" style="animation-delay:.1s;">
          Crea una prenda única impulsada<br />por Google Cloud
        </p>
        <p class="description animate-slide-up" style="animation-delay:.2s;">
          En menos de dos minutos diseñas,<br />nosotros la hacemos realidad
        </p>
      </section>

      <div class="brand-logo animate-slide-up" style="animation-delay:.3s;">
        <img src={gcLogoUrl} alt="Google Cloud" class="gc-logo-img" />
      </div>

      <a
        href="/prenda"
        class="cta-btn animate-slide-up"
        style="animation-delay:.4s;"
      >
        Empezar
        <svg
          class="cta-arrow"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
        </svg>
      </a>

      <div class="event-strip animate-slide-up" style="animation-delay:.5s;">
        <div class="event-pill">
          <svg
            class="cloud-ico"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M19.35 10.04A7.49 7.49 0 0012 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 000 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"
              fill="url(#gcloud-grad)"></path>
            <defs>
              <linearGradient
                id="gcloud-grad"
                x1="0"
                y1="0"
                x2="24"
                y2="24"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#4285F4"></stop>
                <stop offset="50%" stop-color="#34A853"></stop>
                <stop offset="100%" stop-color="#FBBC04"></stop>
              </linearGradient>
            </defs>
          </svg>
          <span class="event-label">Google Cloud Day</span>
          <span class="event-sep" aria-hidden="true">·</span>
          <span class="event-date">Mayo 27, 2026</span>
        </div>
      </div>
    </main>
  </body>
</html>

<style>
  /* Tus estilos se mantienen intactos */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html {
    background: #ffffff;
  }
  .welcome-body {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    font-family: "Google Sans", "Inter", sans-serif;
    overflow: hidden;
    position: relative;
  }
  .hero-svg-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    max-width: clamp(280px, 80vw, 450px);
    pointer-events: none;
    z-index: 5;
    opacity: 0.9;
  }
  @media (min-width: 1024px) {
    .hero-svg-container {
      max-width: 600px;
    }
  }
  .hero-anim-wrapper {
    will-change: transform;
  }
  .corner {
    position: fixed;
    pointer-events: none;
    z-index: 2;
  }
  .corner-img {
    width: 100%;
    height: auto;
    display: block;
  }
  .corner-tr {
    top: 5%;
    right: 5%;
    width: 320px;
    z-index: 15;
  }
  .corner-ml {
    top: 35%;
    left: 8%;
    width: 120px;
    z-index: 15;
  }
  .welcome-card {
    position: relative;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1rem, 4vh, 3rem);
    padding: clamp(2rem, 5vh, 4rem) 1.5rem;
    max-width: 700px;
    width: 100%;
    text-align: center;
  }
  @media (min-width: 1024px) {
    .welcome-card {
      max-width: 900px;
      padding: 4rem;
    }
  }
  .dot-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .dot {
    display: block;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    animation: dot-jump 1.4s infinite ease-in-out;
    will-change: transform;
  }
  @keyframes dot-jump {
    0%,
    80%,
    100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(-12px);
    }
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }
  .greeting {
    font-size: clamp(2.2rem, 10vw, 3.5rem);
    font-weight: 500;
    color: #5f6368;
    line-height: 1.1;
  }
  @media (min-width: 1024px) {
    .greeting {
      font-size: clamp(3.5rem, 5vw, 4.5rem);
    }
  }
  .subtitle {
    font-size: clamp(1.4rem, 5vw, 1.8rem);
    color: #80868b;
    line-height: 1.3;
  }
  @media (min-width: 1024px) {
    .subtitle {
      font-size: 2.2rem;
    }
  }
  .description {
    font-size: clamp(1rem, 3vw, 1.2rem);
    font-weight: 300;
    color: #9aa0a6;
    line-height: 1.5;
  }
  .brand-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 55px;
    margin: 0.5rem 0;
  }
  .gc-logo-img {
    height: 100%;
    width: auto;
    object-fit: contain;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: #4285f4;
    color: #ffffff;
    border-radius: 9999px;
    font-size: clamp(1.1rem, 4vw, 1.5rem);
    font-weight: 600;
    padding: clamp(0.9rem, 2vh, 1.1rem) clamp(2rem, 10vw, 4.5rem);
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(66, 133, 244, 0.4);
    transition: all 200ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .cta-btn:hover {
    background: #3367d6;
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 10px 32px rgba(66, 133, 244, 0.5);
  }
  .cta-arrow {
    width: 1.5rem;
    height: 1.5rem;
    transition: transform 200ms ease;
  }
  .cta-btn:hover .cta-arrow {
    transform: translateX(6px);
  }
  .event-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(66, 133, 244, 0.08);
    border: 1px solid rgba(66, 133, 244, 0.25);
    border-radius: 9999px;
    padding: 0.5rem 1.25rem;
    animation: pill-pulse 3s infinite ease-in-out;
  }
  @keyframes pill-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.03);
      opacity: 0.9;
    }
  }
  .cloud-ico {
    width: 1.1rem;
    height: 1.1rem;
  }
  .event-label {
    font-weight: 700;
    color: #4285f4;
    font-size: 0.9rem;
  }
  .event-sep {
    color: rgba(66, 133, 244, 0.35);
    margin: 0 4px;
  }
  .event-date {
    font-weight: 500;
    color: #5f6368;
    font-size: 0.9rem;
  }
  @keyframes slide-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-slide-up {
    animation: slide-up 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
</style>

<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    // 1. ANIMACIÓN CIEMPIÉS (GUSANO)
    // Blindamos la selección del grupo raíz
    const rootGroup = document.querySelector("#Capa_1-2 > g");

    if (rootGroup) {
      // Capturamos a los hijos directos [G, Image, G]
      const nodes = Array.from(rootGroup.children);

      console.log("Piezas del gusano detectadas:", nodes.length);

      const centipedeTl = gsap.timeline({ repeat: -1, yoyo: true });
      centipedeTl.to(nodes, {
        y: -35,
        rotation: 4,
        scale: 1.04,
        duration: 2.5,
        ease: "sine.inOut",
        stagger: 0.3, // Esto crea el efecto cadena/ola
        force3D: true,
      });
    }

    // 2. CICLO DE COLORES
    const colors = ["#EA4335", "#FBBC04", "#34A853", "#4285F4"];
    const colorTl = gsap.timeline({ repeat: -1 });
    colors.forEach((color) => {
      colorTl.to(".cls-1", { fill: color, duration: 2, ease: "none" });
    });

    // 3. PARALLAX INTERNO
    // Selector ultra-preciso para las nubes internas
    const p1 = document.querySelector("#parallax-img-1 image");
    const p2 = document.querySelector("#parallax-img-2");

    if (p1 || p2) {
      window.addEventListener("mousemove", (e) => {
        const centerX = window.innerWidth / 2;
        const centerY = window.innerHeight / 2;
        const normX = (e.clientX - centerX) / centerX;
        const normY = (e.clientY - centerY) / centerY;

        const maxMove = 20;

        // Movimiento suave y hardware accelerated
        gsap.to([p1, p2], {
          x: normX * maxMove,
          y: normY * maxMove,
          duration: 1.2,
          ease: "power2.out",
          force3D: true,
        });
      });
    }
  });
</script>
