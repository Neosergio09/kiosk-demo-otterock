---
import "../styles/global.css";
import { supabase } from '../lib/supabase';

// ── Asset imports ──────
import recurso1Url from "../assets/models/Recurso 1.svg?url";
import recurso3Url from "../assets/models/Recurso 3.svg?url";
import botonVolverUrl from "../assets/models/Botón Volver.svg?url";
import camisaBlancaImg from "../assets/models/CamisaBlanca.png";
import camisaNegraImg from "../assets/models/CamisaNegra.png";
import totebagCremaImg from "../assets/models/TotebagCrema.png";
import totebagNegraImg from "../assets/models/TotebagNegra.png";

// Opciones de talla estándar
const sizes = [
  { id: 'S', label: 'S' },
  { id: 'M', label: 'M' },
  { id: 'L', label: 'L' },
  { id: 'XL', label: 'XL' }
];

// Si necesitas la lista de productos para el fallback visual de la prenda elegida:
let garments = [];
try {
  const { data } = await supabase.from('products').select('id, name, description, image_url').limit(4);
  garments = data || [];
} catch (e) {
  // Silent fallback
}
if (garments.length === 0) {
  garments = [
    { id: 'tshirt-black', name: 'Camiseta Negra', description: '100% algodón', image_url: camisaNegraImg.src },
    { id: 'tshirt-white', name: 'Camiseta Blanca', description: '100% algodón', image_url: camisaBlancaImg.src },
    { id: 'totebag-crema', name: 'Totebag Crema', description: '100% algodón', image_url: totebagCremaImg.src },
    { id: 'totebag-black', name: 'Totebag Negra', description: '100% algodón', image_url: totebagNegraImg.src },
  ];
} else {
  garments = garments.map((g: any) => {
    if(g.id === 'tshirt-black' || g.id === '1') g.image_url = camisaNegraImg.src;
    if(g.id === 'tshirt-white' || g.id === '2') g.image_url = camisaBlancaImg.src;
    if(g.id === 'totebag-crema' || g.id === '3') g.image_url = totebagCremaImg.src;
    if(g.id === 'totebag-black' || g.id === '4') g.image_url = totebagNegraImg.src;
    return g;
  });
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#FFFFFF" />
    <title>Paso 2: Talla — Google Cloud Day</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Inter:wght@300;400;500;600;700;800;900&family=Roboto+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>

  <body class="welcome-body">
    <!-- DECORATIVE CORNERS -->
    <div class="corner corner-tr" aria-hidden="true">
      <img src={recurso3Url} alt="" class="corner-img" />
    </div>
    <div class="corner corner-ml" aria-hidden="true">
      <img src={recurso1Url} alt="" class="corner-img" />
    </div>

    <!-- JSON Oculto para que el JS sepa qué prenda mapear -->
    <script type="application/json" id="garments-data">{JSON.stringify(garments)}</script>

    <main class="welcome-card">
      <div class="dot-row" aria-hidden="true">
        <span class="dot" style="background:#4285F4; animation-delay: 0s;"></span>
        <span class="dot" style="background:#EA4335; animation-delay: 0.1s;"></span>
        <span class="dot" style="background:#FBBC04; animation-delay: 0.2s;"></span>
        <span class="dot" style="background:#34A853; animation-delay: 0.3s;"></span>
      </div>

      <header class="hero-text">
        <h1 class="greeting animate-slide-up" style="font-size:2.5rem;">Paso 2</h1>
        <p class="subtitle animate-slide-up" style="animation-delay:.1s; font-size:1.5rem;">
          ¿Qué talla prefieres?
        </p>
      </header>

      <!-- Prenda seleccionada en Paso 1 (Dinámico) -->
      <div class="animate-slide-up" style="animation-delay:.2s; display:flex; flex-direction:column; align-items:center; gap:0.5rem; margin-top:0.5rem;">
        <div id="selected-garment-preview" class="w-32 h-32 lg:w-40 lg:h-40 bg-stone-50 rounded-2xl flex items-center justify-center p-3 border border-zinc-200 shadow-sm transition-all overflow-hidden">
           <img src={camisaBlancaImg.src} alt="Camiseta Blanca" class="w-full h-full object-contain drop-shadow-sm opacity-50" id="preview-img-tag" />
        </div>
        <div class="w-48 h-16 bg-neutral-200 rounded-2xl flex flex-col items-center justify-center -mt-2">
          <span id="selected-name" class="text-center justify-start text-blue-500 text-base font-medium font-['Montserrat']">Camiseta Blanca</span>
          <span id="selected-desc" class="text-center justify-start text-neutral-400 text-sm font-light font-['Montserrat']">100% algodón</span>
        </div>
      </div>

      <!-- TALLAS GRID -->
      <section class="w-full max-w-lg lg:max-w-3xl flex flex-wrap justify-center gap-4 md:gap-8 relative z-10 my-6">
        {sizes.map((s, i) => (
          <button 
            class="size-card group relative w-20 h-20 md:w-24 md:h-24 lg:w-32 lg:h-32 bg-stone-50 rounded-2xl flex items-center justify-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg border-2 border-transparent animate-slide-up"
            data-id={s.id}
            style={`animation-delay: ${0.3 + (i * 0.1)}s;`}
          >
            <!-- Meta (Talla) -->
            <span class="text-neutral-400 text-xl sm:text-2xl md:text-3xl lg:text-4xl font-medium font-sans size-label transition-colors">{s.label}</span>

            <!-- Indicador de selección oculto -->
            <div class="selection-ring absolute inset-0 rounded-2xl border-4 border-[#4285F4] opacity-0 transition-opacity duration-300 pointer-events-none"></div>
          </button>
        ))}
      </section>

      <footer class="flex flex-col items-center gap-6 mt-2 w-full animate-slide-up" style="animation-delay:0.7s;">
        <div class="flex flex-col gap-4 w-full items-center">
          <!-- Botón Continuar (Deshabilitado por defecto) -->
          <button 
            id="btn-continuar"
            disabled
            class="cta-btn disabled:opacity-50 disabled:cursor-not-allowed disabled:shadow-none disabled:hover:transform-none disabled:hover:bg-[#4285f4]"
            style="width: 100%; max-width: 400px;"
          >
            Continuar
            <svg class="cta-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </button>

          <!-- Botón Volver -->
          <a href="/prenda" class="group flex items-center justify-center transition-transform hover:-translate-y-1 mt-2">
            <img src={botonVolverUrl} alt="Volver" class="h-12 w-auto object-contain" />
          </a>
        </div>

        <div class="event-strip">
          <div class="event-pill">
            <span class="event-label">Escoge tu talla y continúa</span>
          </div>
        </div>
      </footer>
    </main>
  </body>
</html>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html {
    background: #ffffff;
  }
  .welcome-body {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    font-family: "Google Sans", "Inter", sans-serif;
    overflow: hidden;
    position: relative;
  }
  .corner {
    position: fixed;
    pointer-events: none;
    z-index: 2;
  }
  .corner-img {
    width: 100%;
    height: auto;
    display: block;
  }
  .corner-tr {
    top: 5%;
    right: 5%;
    width: 320px;
    z-index: 15;
  }
  .corner-ml {
    top: 35%;
    left: 8%;
    width: 120px;
    z-index: 15;
  }
  .welcome-card {
    position: relative;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.75rem, 3vh, 1.5rem);
    padding: clamp(1.5rem, 4vh, 2rem) 1.25rem;
    max-width: 800px;
    width: 100%;
    text-align: center;
  }
  @media (min-width: 1024px) {
    .welcome-card {
      max-width: 1000px;
      padding: 3rem;
    }
  }
  .dot-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .dot {
    display: block;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    animation: dot-jump 1.4s infinite ease-in-out;
    will-change: transform;
  }
  @keyframes dot-jump {
    0%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-12px); }
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }
  .greeting {
    font-size: clamp(2rem, 8vw, 2.5rem);
    font-weight: 500;
    color: #5f6368;
  }
  @media (min-width: 1024px) {
    .greeting {
      font-size: 3.5rem;
    }
  }
  .subtitle {
    font-size: clamp(1.1rem, 4vw, 1.5rem);
    color: #80868b;
  }
  @media (min-width: 1024px) {
    .subtitle {
      font-size: 2rem;
    }
  }
  
  /* Selección de talla activa */
  .size-card.active {
    background-color: #eff6ff; /* blue-50 */
  }
  .size-card.active .size-label {
    color: #4285F4;
    font-weight: 700;
    transform: scale(1.1);
  }
  .size-card.active .selection-ring {
    opacity: 1;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: #4285f4;
    color: #ffffff;
    border-radius: 9999px;
    font-size: clamp(1.1rem, 4vw, 1.5rem);
    font-weight: 600;
    padding: clamp(0.9rem, 2vh, 1.1rem) clamp(2rem, 10vw, 4.5rem);
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(66, 133, 244, 0.4);
    transition: all 200ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
    border: none;
  }
  .cta-btn:hover:not(:disabled) {
    background: #3367d6;
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 10px 32px rgba(66, 133, 244, 0.5);
  }
  .cta-arrow {
    width: 1.5rem;
    height: 1.5rem;
    transition: transform 200ms ease;
  }
  .cta-btn:hover:not(:disabled) .cta-arrow {
    transform: translateX(6px);
  }
  .event-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(66, 133, 244, 0.08);
    border: 1px solid rgba(66, 133, 244, 0.25);
    border-radius: 9999px;
    padding: 0.5rem 1.25rem;
    animation: pill-pulse 3s infinite ease-in-out;
  }
  @keyframes pill-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.03); opacity: 0.9; }
  }
  .event-label {
    font-weight: 500;
    color: #4285f4;
    font-size: 0.9rem;
  }
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-slide-up {
    animation: slide-up 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Restaurar la prenda seleccionada del paso anterior
    const urlParams = new URLSearchParams(window.location.search);
    const garmentId = urlParams.get("garmentId") || sessionStorage.getItem('selectedGarmentId');
    if (!garmentId) {
      window.location.href = "/prenda";
      return;
    }

    try {
      const gData = JSON.parse(document.getElementById('garments-data')?.textContent || '[]');
      const gItem = gData.find((g: any) => g.id === garmentId);
      if (gItem) {
        document.getElementById('selected-name')!.textContent = gItem.name;
        document.getElementById('selected-desc')!.textContent = gItem.description;
        const previewImg = document.getElementById('preview-img-tag') as HTMLImageElement;
        if (gItem.image_url && previewImg) {
          previewImg.src = gItem.image_url;
          previewImg.classList.remove('opacity-50');
          previewImg.classList.add('opacity-100');
        }
      }
    } catch(e) {}

    // Lógica de Selección de Talla
    const cards = document.querySelectorAll('.size-card');
    const btnContinuar = document.getElementById('btn-continuar') as HTMLButtonElement | null;
    let selectedSizeId: string | null = null;

    cards.forEach(card => {
      card.addEventListener('click', () => {
        cards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        
        selectedSizeId = card.getAttribute('data-id');
        
        card.animate([
          { transform: 'scale(0.95)' },
          { transform: 'scale(1)' }
        ], { duration: 250, easing: 'cubic-bezier(0.175, 0.885, 0.32, 1.275)' });

        if (btnContinuar) {
          btnContinuar.removeAttribute('disabled');
        }
      });
    });

    // Enviar resultado al Editor (Paso 3)
    btnContinuar?.addEventListener('click', () => {
      if(selectedSizeId && garmentId) {
        sessionStorage.setItem('selectedSizeId', selectedSizeId);
        window.location.href = `/editor?garmentId=${garmentId}&size=${selectedSizeId}`;
      }
    });
  });
</script>
