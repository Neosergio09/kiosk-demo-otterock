---
import Layout from "../../layouts/Layout.astro";
import PatchEditor from "../../components/PatchEditor.astro";
import { actions } from "astro:actions";

const { id } = Astro.params;

// Redirect if id is missing (shouldn't happen with dynamic route)
if (!id) return Astro.redirect("/prenda");

// ── POST handler ──────────────────────────────────────────────────────────────
const result = await Astro.getActionResult(actions.createPersonalizedOrder);

if (result?.data?.success) return Astro.redirect('/care-instructions');

const actionError = result?.error;
---

<Layout title="Personaliza tu Prenda — Google Cloud Day" step={3}>
  {
    /* ═══════════════════════════════════════════════════════════════════
       ERROR BANNER — Material style: white card, red left border
  ═══════════════════════════════════════════════════════════════════ */
  }
  {
    actionError && (
      <div
        id="error-banner"
        class="mx-5 lg:mx-12 mt-4 rounded-2xl lg:rounded-3xl px-5 py-4 lg:px-8 lg:py-5 flex items-center gap-4 animate-fadeInUp shrink-0 border border-[#DADCE0]"
        style="background:#FFFFFF; border-left: 4px solid #EA4335; box-shadow: 0 1px 6px rgba(60,64,67,0.12);"
      >
        <div
          class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0"
          style="background: rgba(234,67,53,0.10);"
        >
          <svg
            class="w-6 h-6"
            style="color:#EA4335;"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"
            />
          </svg>
        </div>
        <p class="text-lg lg:text-2xl font-medium" style="color:#202124;">
          {actionError.message}
        </p>
      </div>
    )
  }

  {
    /* ═══════════════════════════════════════════════════════════════════
       MAIN FORM (Organizado al centro)
  ═══════════════════════════════════════════════════════════════════ */
  }
  {
    /* Form always renders — on success the server redirects before reaching here */
  }
  <form
        id="personalization-form"
        method="POST"
        enctype="multipart/form-data"
        action={actions.createPersonalizedOrder}
      >
        <div class="px-5 sm:px-8 lg:px-10 pt-4 lg:pt-6 pb-6 max-w-4xl mx-auto w-full flex flex-col items-center">
          <input
            type="hidden"
            name="garmentType"
            id="garmentTypeInput"
            value={id}
            required
          />
          <input type="hidden" name="size" id="sizeInput" required />
          <input type="hidden" name="color" value="Blanco" />

          <div
            class="w-full rounded-3xl border border-[#DADCE0] overflow-hidden"
            style="background:#F8F9FA;"
          >
            <PatchEditor garmentId={id} />
          </div>

          <div class="pt-8 lg:pt-12 w-full max-w-xl">
            <button
              id="submit-btn"
              type="submit"
              class="w-full font-bold text-lg lg:text-2xl py-5 lg:py-6 rounded-3xl cursor-pointer transition-all duration-200"
              style="
                background: #4285F4;
                color: #FFFFFF;
                box-shadow: 0 4px 20px rgba(66,133,244,0.3);
              "
              onmouseover="this.style.background='#3367D6'; this.style.transform='translateY(-2px)';"
              onmouseout="this.style.background='#4285F4'; this.style.transform='translateY(0)';"
              onmousedown="this.style.transform='scale(0.98)';"
              onmouseup="this.style.transform='translateY(-2px)';"
            >
              <span
                id="btn-label"
                class="flex items-center justify-center gap-4"
              >
                CONFIRMAR PEDIDO
              </span>
              <span
                id="btn-loading"
                class="hidden items-center justify-center gap-4"
              >
                <svg
                  class="w-7 h-7 lg:w-8 lg:h-8 shrink-0"
                  viewBox="0 0 24 24"
                  fill="none"
                  style="animation: spin-slow 0.9s linear infinite;"
                >
                  <circle
                    cx="12"
                    cy="12"
                    r="10"
                    stroke="white"
                    stroke-width="3"
                    stroke-opacity="0.3"
                  />
                  <path
                    d="M12 2a10 10 0 0110 10"
                    stroke="white"
                    stroke-width="3"
                    stroke-linecap="round"
                  />
                </svg>
                Enviando…
              </span>
            </button>
          </div>
        </div>
      </form>
</Layout>

<script>
  // ── Load Garment from previous step ─────────────────────────────────────
  document.addEventListener("DOMContentLoaded", () => {
    const hiddenInput = document.getElementById(
      "garmentTypeInput",
    ) as HTMLInputElement;
    const urlParams = new URLSearchParams(window.location.search);

    // We already have 'id' injected from the server into the hidden input value
    const garmentId = hiddenInput.value || sessionStorage.getItem("selectedGarmentId");
    const sizeId = urlParams.get("size") || sessionStorage.getItem("selectedSizeId");

    if (garmentId) {
      if (!hiddenInput.value) hiddenInput.value = garmentId;
    } else {
      window.location.href = "/prenda";
    }

    const hiddenSizeInput = document.getElementById(
      "sizeInput",
    ) as HTMLInputElement;
    if (sizeId && hiddenSizeInput) {
      hiddenSizeInput.value = sizeId;
    } else if (garmentId) {
      window.location.href = "/talla?garmentId=" + garmentId;
    }
  });

  // ── Submit Logic ──
  const form = document.getElementById(
    "personalization-form",
  ) as HTMLFormElement | null;
  const btnLabel = document.getElementById("btn-label");
  const btnLoading = document.getElementById("btn-loading");
  const submitBtn = document.getElementById(
    "submit-btn",
  ) as HTMLButtonElement | null;

  form?.addEventListener("submit", () => {
    btnLabel?.classList.add("hidden");
    btnLoading?.classList.remove("hidden");
    btnLoading?.classList.add("flex");
    if (submitBtn) submitBtn.disabled = true;
  });

  // ── Auto-dismiss error ──
  const errorBanner = document.getElementById("error-banner");
  if (errorBanner) {
    setTimeout(() => {
      errorBanner.style.transition = "opacity 0.5s ease";
      errorBanner.style.opacity = "0";
      setTimeout(() => errorBanner.remove(), 520);
    }, 6000);
  }
</script>
